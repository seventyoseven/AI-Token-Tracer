<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Assign admin user to both AI User and AI Manager groups -->
        <record id="group_ai_token_tracker_user" model="res.groups">
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>
        
        <record id="group_ai_token_tracker_manager" model="res.groups">
            <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
