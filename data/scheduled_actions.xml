<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Scheduled Action: Check Budget Alerts -->
        <record id="ir_cron_check_budget_alerts" model="ir.cron">
            <field name="name">AI Monitor: Check Budget Alerts</field>
            <field name="model_id" ref="model_ai_monitor_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_budget_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Scheduled Action: Send Monthly Reports -->
        <record id="ir_cron_send_monthly_reports" model="ir.cron">
            <field name="name">AI Monitor: Send Monthly Reports</field>
            <field name="model_id" ref="model_ai_monitor_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_monthly_reports()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=30)).replace(day=1, hour=9, minute=0, second=0)"/>
        </record>

        <!-- Scheduled Action: Clean Old Logs (Optional) -->
        <record id="ir_cron_clean_old_logs" model="ir.cron">
            <field name="name">AI Monitor: Archive Old Usage Logs</field>
            <field name="model_id" ref="model_ai_monitor_usage_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_archive_old_logs()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
