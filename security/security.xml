<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Security Groups -->
        <record id="group_ai_monitor_user" model="res.groups">
            <field name="name">AI Monitor User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">
                Basic user who can view AI usage logs and subscriptions
            </field>
        </record>

        <record id="group_ai_monitor_manager" model="res.groups">
            <field name="name">AI Monitor Manager</field>
            <field name="implied_ids" eval="[(4, ref('group_ai_monitor_user'))]"/>
            <field name="comment">
                Manager who can create/modify subscriptions, models, and view all analytics
            </field>
        </record>

        <record id="group_ai_monitor_admin" model="res.groups">
            <field name="name">AI Monitor Administrator</field>
            <field name="implied_ids" eval="[(4, ref('group_ai_monitor_manager'))]"/>
            <field name="comment">
                Administrator with full access to all AI monitoring features including system configuration
            </field>
        </record>

        <!-- Record Rules for ai_monitor.provider -->
        <record id="ai_monitor_provider_rule_user" model="ir.rule">
            <field name="name">AI Provider: User Access</field>
            <field name="model_id" ref="model_ai_monitor_provider"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_monitor_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="ai_monitor_provider_rule_manager" model="ir.rule">
            <field name="name">AI Provider: Manager Full Access</field>
            <field name="model_id" ref="model_ai_monitor_provider"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_monitor_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules for ai_monitor.subscription -->
        <record id="ai_monitor_subscription_rule_user" model="ir.rule">
            <field name="name">AI Subscription: User Read Access</field>
            <field name="model_id" ref="model_ai_monitor_subscription"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_monitor_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="ai_monitor_subscription_rule_manager" model="ir.rule">
            <field name="name">AI Subscription: Manager Full Access</field>
            <field name="model_id" ref="model_ai_monitor_subscription"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_monitor_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules for ai_monitor.usage_log -->
        <record id="ai_monitor_usage_log_rule_user" model="ir.rule">
            <field name="name">AI Usage Log: User Access</field>
            <field name="model_id" ref="model_ai_monitor_usage_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_monitor_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="ai_monitor_usage_log_rule_manager" model="ir.rule">
            <field name="name">AI Usage Log: Manager Full Access</field>
            <field name="model_id" ref="model_ai_monitor_usage_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_monitor_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
