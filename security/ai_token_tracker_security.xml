<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Security Groups -->
        <record id="group_ai_token_tracker_user" model="res.groups">
            <field name="name">AI User</field>
            <field name="comment">
                User can see their own AI usage, API keys, and the main dashboard.
            </field>
        </record>

        <record id="group_ai_token_tracker_manager" model="res.groups">
            <field name="name">AI Manager</field>
            <field name="comment">
                Manager can configure providers, models, subscriptions,
                and see all usage logs. Can also view/manage all API keys.
            </field>
            <field name="implied_ids" eval="[(4, ref('group_ai_token_tracker_user'))]"/>
        </record>
        
        <record id="ai_api_key_rule_user_self" model="ir.rule">
            <field name="name">AI API Key: User can only see their own</field>
            <field name="model_id" ref="model_ai_token_tracker_api_key"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ai_token_tracker_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
          
        <record id="ai_api_key_rule_manager_all" model="ir.rule">
            <field name="name">AI API Key: Manager can see all</field>
            <field name="model_id" ref="model_ai_token_tracker_api_key"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_token_tracker_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="ai_usage_log_rule_user_self" model="ir.rule">
            <field name="name">AI Usage Log: User can only see their own</field>
            <field name="model_id" ref="model_ai_token_tracker_usage_log"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_ai_token_tracker_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/> 
        </record>

        <record id="ai_usage_log_rule_manager_all" model="ir.rule">
            <field name="name">AI Usage Log: Manager can see all</field>
            <field name="model_id" ref="model_ai_token_tracker_usage_log"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_ai_token_tracker_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>